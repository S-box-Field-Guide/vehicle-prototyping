          "op": "between",
          "value": [
            0.0,
            60.0
          ],
          "note": "measured launch wheelspin duration; the Sport launch-feel signal"
        },
        {
          "metric": "pitchDeg",
          "op": "between",
          "value": [
            0.0,
            45.0
          ],
          "note": "squat sanity; data cell"
        },
