{
  "bands": "handling-targets v1",
  "note": "figure8 3-assist-level sweep ('clean under all 3 assist levels'): 4 cars x Casual(0)/Sport(1)/Sim(2) = 12 rows (grown 2026-07-13 wave-2 from the 4 one-assist-per-car rows). Per-car lateral-g bands are UNCHANGED across the three assist levels -- they are anchored on each car's MEASURED baseline-metrics skidpad reality (docs/handling-targets.md figure8 provenance table), and the grip envelope is the same envelope the player's assist layer sits on top of; the sweep proves the pass SHAPE (no spin, in-band g) holds under every assist, not three different targets. assist re-applied every tick by the pilot (docs/testing-harness.md §7.1). Bands are v1 -- pre-measurement; aspirational rows may honest-red (do not tune).",
  "suite": [
    {
      "maneuver": "figure8",
      "car": "hatch",
      "station": "skidpad",
      "params": { "radiusM": 20.0, "lobes": 2, "assist": 0, "maxRunS": 35.0 },
      "asserts": [
        { "metric": "lateralGAvg", "op": "between", "value": [0.55, 0.80], "note": "measured skidpad 0.687 g anchor (NOT the aspirational 0.80-0.90 skidpad band). Casual (assist:0) = hatch default. v1 -- pre-measurement" },
        { "metric": "lateralGPeak", "op": "<=", "value": 0.95, "note": "lobe-consistency proxy (no per-lobe telemetry field). v1 -- pre-measurement" },
        { "metric": "yawRateAvgDeg", "op": "between", "value": [5.0, 60.0], "note": "steady-state yaw stability sanity (skidpad.json style)" },
        { "metric": "spunOut", "op": "==", "value": false, "note": "figure8 pass shape: clean transitions = no spin-out. §6.2 spunOut maneuver list extended to cover figure8" },
        { "metric": "flips", "op": "==", "value": 0, "note": "standing invariant audit (target 0)" },
        { "metric": "elapsedS", "op": "<=", "value": 35.0, "note": "completion sanity (DNF guard, mirrors slalom.json)" }
      ]
    },
