
# This file describes files and paths that should not be tracked by Git version control
# https://git-scm.com/docs/gitignore

# Auto-generated code editor files
.vs/*
.vscode/*
*.csproj
obj
bin
Properties/*
code/obj/*
code/Properties/*

# Auto-generated asset related files
.sbox/*
*.generated.*
*.*_c
!*.shader_c
*.los
*.vpk
*launchSettings.json
*.sln
*.slnx

*idea

# Exported / standalone games
Exports/

# Python tooling bytecode (tools/*.py) — generated, version-specific
tools/__pycache__/
__pycache__/
*.pyc

# Local console-capture scratch file (tools)
tools/_console_tail.txt

# Owner-local launch/store drafts (not for the public tree)
docs/news-post-launch.md
docs/sandbox-listing.md
